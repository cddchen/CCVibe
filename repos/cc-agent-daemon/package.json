{
  "name": "cc-agent-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local daemon wrapping Claude Agent SDK for multi-client session management",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.4.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}